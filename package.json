    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/streamifier": "^0.1.2",
    "eslint": "^9.38.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }

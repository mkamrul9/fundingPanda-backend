{
  "name": "fundingpanda-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsup src/server.ts --format cjs --clean",
    "build:prod": "tsup src/server.ts --out-dir dist --format cjs --target node18 --clean --minify",
    "build:render": "npx prisma db push && npx prisma generate && npm run seed && npm run build",
    "db:push": "npx prisma db push",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node dist/server.cjs",
    "start:prod": "node dist/server.cjs",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint .",
    "seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-auth": "^1.5.5",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "stripe": "^20.4.1",
    "prisma": "^7.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },

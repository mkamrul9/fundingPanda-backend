
generator client {
  provider        = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
}


model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  role          UserRole  @default(STUDENT)
  image         String?
  bio           String?
  emailVerified Boolean   @default(false)   // Required by BetterAuth
  university    String?   // Custom field for BetterAuth
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // BetterAuth Relations
  sessions      Session[]
  accounts      Account[]

  // Relations
  projects      Project[]
  hardwares     Hardware[]
  donations     Donation[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  expiresAt             DateTime?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  @@map("verifications")
}

model Project {
  id            String        @id @default(uuid())
  title         String
  description   String
  goalAmount    Float
  raisedAmount  Float         @default(0)

  // New Fields for Pitch Files
  pitchVideoUrl String?  
  pitchDocUrl   String?  
  images        String[] 
  adminFeedback String? // NEW: Admin notes for rejected/pending projects

  status        ProjectStatus @default(PENDING)
  studentId     String
  student       User          @relation(fields: [studentId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  donations     Donation[]

  @@map("projects")
}

model Hardware {
  id            String   @id @default(uuid())
  name          String
  category      String   // e.g., GPU, Sensor, Microcontroller
  description   String
  isAvailable   Boolean  @default(true)
  lenderId      String
  lender        User     @relation(fields: [lenderId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("hardwares")
}

model Donation {
  id        String   @id @default(uuid())
  amount    Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@map("donations")
}

enum UserRole {
  STUDENT
  SPONSOR
  ADMIN
}

enum ProjectStatus {
  PENDING
  APPROVED
  FUNDED
  COMPLETED
}

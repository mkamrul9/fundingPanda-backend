model Donation {
  id        String   @id @default(uuid())
  amount    Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@map("donations")
}

enum UserRole {
  STUDENT
  SPONSOR
  ADMIN
}

enum ProjectStatus {
  PENDING
  APPROVED
  FUNDED
  COMPLETED
}

enum ResourceType {
  HARDWARE
  SOFTWARE
}
